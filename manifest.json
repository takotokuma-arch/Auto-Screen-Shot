{
  "manifest_version": 3,
  "name": "Auto Screen Shot",
  "version": "2.0",
  "description": "Automate screenshots of specific areas and page transitions.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "offscreen",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auto Screen Shot"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
